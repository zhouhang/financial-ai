# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tally
DB_USER=tally_user
DB_PASSWORD=your_password_here

# MCP 服务器配置
MCP_SERVER_HOST=0.0.0.0
MCP_PUBLIC_HOST=localhost
MCP_SERVER_PORT=3335

# 文件存储配置
UPLOAD_MAX_SIZE=104857600
FILE_RETENTION_DAYS=30

# 存储后端：本地开发用 local，生产使用 OSS 私有 Bucket
STORAGE_BACKEND=local
OSS_BUCKET=
OSS_ENDPOINT=
OSS_REGION=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PREFIX=financial-ai/dev
OSS_PRESIGN_EXPIRE_SECONDS=900
OSS_UPLOAD_MAX_SIZE=104857600

# 任务配置
TASK_TIMEOUT=3600
MAX_CONCURRENT_TASKS=5

# LangSmith 追踪（写在 finance-agents/data-agent/.env 中，用于 Tally 的 LLM 调用监控）
# 在 https://smith.langchain.com/settings 获取 API Key
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=Tally

# 回填差异消化(finance-cron 定时,凌晨对最近 N 天仍有 open 差异的历史 run 重判一次,
# 让 source_only 在结算账单到达后被关闭。对所有对账任务统一生效,不分平台)
FINANCE_CRON_SWEEP_DIGESTION_ENABLED=true   # kill-switch:设 false 即停(已关差异不回弹)
FINANCE_CRON_SWEEP_DIGESTION_HOUR=3         # 每日运行时辰(0-23,Asia/Shanghai)
FINANCE_CRON_DIGESTION_WINDOW_DAYS=15       # 回溯窗口天数(覆盖最长结算 PDD T+14)
