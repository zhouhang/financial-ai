# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tally
DB_USER=tally_user
DB_PASSWORD=your_password_here

# MCP 服务器配置
MCP_SERVER_HOST=0.0.0.0
MCP_PUBLIC_HOST=localhost
MCP_SERVER_PORT=3335

# 文件存储配置
UPLOAD_MAX_SIZE=104857600
FILE_RETENTION_DAYS=30

# 任务配置
TASK_TIMEOUT=3600
MAX_CONCURRENT_TASKS=5

# LangSmith 追踪（写在 finance-agents/data-agent/.env 中，用于 Tally 的 LLM 调用监控）
# 在 https://smith.langchain.com/settings 获取 API Key
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=Tally
