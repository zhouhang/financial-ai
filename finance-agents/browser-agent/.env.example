# Copy this file to finance-agents/browser-agent/.env.
# Do not commit finance-agents/browser-agent/.env.

# Cloud data-agent websocket endpoint. The public Nginx entry routes /api/* to data-agent.
DATA_AGENT_WS_URL=wss://www.tallyai.cn/api/browser-agent

# Must be exactly the same value as JWT_SECRET in /opt/tally/.env.prod on ECS.
JWT_SECRET=replace-with-production-jwt-secret

# Required by the cloud heartbeat and job ownership routing.
BROWSER_AGENT_COMPANY_ID=replace-with-company-id

# Give each collection machine a stable, unique id.
BROWSER_AGENT_ID=collector-mac-1

# Real collection path.
BROWSER_AGENT_RUNNER_MODE=playwright
BROWSER_AGENT_BROWSER_CHANNEL=chrome
BROWSER_AGENT_HEADLESS=0
# Headed Chrome window size. Keep it wide enough for QianNiu drawers/download history.
BROWSER_AGENT_CHROME_WINDOW_WIDTH=1600
BROWSER_AGENT_CHROME_WINDOW_HEIGHT=1000
BROWSER_AGENT_CHROME_WINDOW_X=0
BROWSER_AGENT_CHROME_WINDOW_Y=0
# OS-level handoff injects real desktop input; keep one visible Chrome worker per Windows collector.
BROWSER_AGENT_MAX_CONCURRENCY=1
BROWSER_AGENT_POLL_INTERVAL_SECONDS=2
BROWSER_AGENT_HEARTBEAT_INTERVAL_SECONDS=30
BROWSER_AGENT_TIMEZONE=Asia/Shanghai

# Handoff control backend:
# - os_windows: production Windows collector, captures the real Chrome window and injects native input.
# - playwright: fallback page screenshot/input backend.
# Windows os backend requires the agent to run in a logged-in interactive desktop session.
HANDOFF_CONTROL_BACKEND=os_windows

# Optional persistent local state. Defaults to ~/tally-browser-agent/...
# BROWSER_AGENT_PROFILE_ROOT=/Users/kevin/tally-browser-agent/profiles
# BROWSER_AGENT_DOWNLOAD_ROOT=/Users/kevin/tally-browser-agent/downloads

# 原始下载文件(账单/订单 CSV/XLSX)的存储后端。
# 采集机与云端不在同一台机器时必须用 oss —— 否则文件只留在采集机本地,
# 云端/前端无法下载或审计。以下值要和 ECS /opt/tally/.env.prod 完全一致。
STORAGE_BACKEND=oss
OSS_BUCKET=replace-with-prod-bucket
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=replace-with-key-id
OSS_ACCESS_KEY_SECRET=replace-with-key-secret
# 必须与 prod 一致,capture 路径才对得上(例如 financial-ai/prod)
OSS_PREFIX=replace-with-prod-prefix
