	recon_subgraph\3acheck_file_node -.-> recon_subgraph\3arecon_task_execution_node;
	recon_subgraph\3aget_rule_node -.-> recon_subgraph\3a__end__;
	recon_subgraph\3aget_rule_node -.-> recon_subgraph\3acheck_file_node;
	recon_subgraph\3arecon_task_execution_node --> recon_subgraph\3arecon_result_node;
	recon_subgraph\3arecon_result_node --> recon_subgraph\3a__end__;
	end
	classDef default fill:#f2f0ff,line-height:1.2
