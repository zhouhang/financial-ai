	router -.-> recon_subgraph\3aget_rule_node;
	proc_subgraph\3a__end__ --> __end__;
	recon_subgraph\3a__end__ --> __end__;
	subgraph proc_subgraph
	proc_subgraph\3aget_rule_node(get_rule_node)
	proc_subgraph\3acheck_file_node(check_file_node)
	proc_subgraph\3aproc_task_execute_node(proc_task_execute_node)
	proc_subgraph\3aresult_node(result_node)
	proc_subgraph\3a__end__(<p>__end__</p>)
	proc_subgraph\3acheck_file_node -.-> proc_subgraph\3a__end__;
	proc_subgraph\3acheck_file_node -.-> proc_subgraph\3aproc_task_execute_node;
	proc_subgraph\3aget_rule_node -.-> proc_subgraph\3a__end__;
	proc_subgraph\3aget_rule_node -.-> proc_subgraph\3acheck_file_node;
	proc_subgraph\3aproc_task_execute_node --> proc_subgraph\3aresult_node;
	proc_subgraph\3aresult_node --> proc_subgraph\3a__end__;
	end
	subgraph recon_subgraph
