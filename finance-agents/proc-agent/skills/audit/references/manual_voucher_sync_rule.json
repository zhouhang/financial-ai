{
  "role_desc":"核算部门数据整理规则",
  "rules": [
    {
      "rule_id": "MANUAL_VOUCHER_SYNC_001",
      "description": "手工凭证表同步到BI费用明细表（手工类）的字段映射规则",
      "version": "1.0",
      "source_tables": "手工凭证表",
      "target_table": "BI费用明细表（手工类）",
      "global_filter": {
        "description": "从手工凭证表中过滤相关数据的总体规则",
        "source_column": "科目名称",
        "operator": "in",
        "values": [
          "研发支出_费用化支出",
          "主营业务成本_直接服务费",
          "主营业务成本_工资性支出",
          "其他业务收入",
          "其他业务成本",
          "管理费用",
          "销售费用",
          "财务费用",
          "营业外收入",
          "营业外支出",
          "投资收益",
          "资产减值损失",
          "所得税"
        ],
        "exclude_values": [
          "管理费用-研发费"
        ]
      },
      "field_mappings": [
        {
          "target_field": "日期",
          "rule_type": "direct_mapping",
          "source_field": "业务时间"
        },
        {
          "target_field": "所属公司",
          "rule_type": "direct_mapping",
          "source_field": "公司名称"
        },
        {
          "target_field": "客户",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "店铺_平台",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "数据来源",
          "rule_type": "constant",
          "value": "手工凭证"
        },
        {
          "target_field": "rp单据",
          "rule_type": "direct_mapping",
          "source_field": "凭证号"
        },
        {
          "target_field": "行政中心",
          "rule_type": "direct_mapping",
          "source_field": "行政组织"
        },
        {
          "target_field": "利润中心",
          "rule_type": "direct_mapping",
          "source_field": "行政组织"
        },
        {
          "target_field": "eas一级科目",
          "rule_type": "extract",
          "source_field": "科目名称",
          "extract_level": 1,
          "delimiter": "_",
          "description": "从科目名称中按_截取一级科目"
        },
        {
          "target_field": "费用二级项目",
          "rule_type": "extract",
          "source_field": "科目名称",
          "extract_level": 2,
          "delimiter": "_",
          "description": "从科目名称中按_截取二级科目"
        },
        {
          "target_field": "费用三级项目",
          "rule_type": "extract",
          "source_field": "科目名称",
          "extract_level": 3,
          "delimiter": "_",
          "description": "从科目名称中按_截取三级科目"
        },
        {
          "target_field": "账单上提取规则",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "是否归属店铺费用",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "是否参与综合店铺分摊",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "eas含税金额",
          "rule_type": "formula",
          "formula": "eas不含税金额 * (1 + 税率)",
          "description": "eas含税金额 = eas不含税金额 * (1+税率)，该列为计算列",
          "is_computed": true,
          "depends_on": ["eas不含税金额", "税率"]
        },
        {
          "target_field": "eas不含税金额",
          "rule_type": "formula",
          "formula": "借方发生额 + 贷方发生额",
          "description": "eas不含税金额 = 借方发生额 + 贷方发生额，其中借方发生额和贷方发生额的值来自来手工凭证表",
          "source_fields": [
            {"field": "借方发生额", "source_table": "手工凭证表"},
            {"field": "贷方发生额", "source_table": "手工凭证表"}
          ]
        },
        {
          "target_field": "eas税额",
          "rule_type": "formula",
          "formula": "eas含税金额 - eas不含税金额",
          "description": "eas税额 = eas含税金额 - eas不含税金额，该列为计算列",
          "is_computed": true,
          "depends_on": ["eas含税金额", "eas不含税金额"]
        },
        {
          "target_field": "费用项目",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "报表取数",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "报表利润中心id",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "报表利润中心",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "报表费用类型",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "是否公摊",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "中心群",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "摘要备注",
          "rule_type": "direct_mapping",
          "source_field": "摘要"
        },
        {
          "target_field": "月分区",
          "rule_type": "direct_mapping",
          "source_field": "月份"
        },
        {
          "target_field": "备注",
          "rule_type": "constant",
          "value": null
        },
        {
          "target_field": "税率",
          "rule_type": "parse_from_field",
          "source_field": "摘要",
          "parse_rules": [
            {
              "step": 1,
              "description": "按&分割摘要，提取调整类型列",
              "split_by": "&",
              "extract_index": 1,
              "result_field": "调整类型"
            },
            {
              "step": 2,
              "description": "从调整类型中按+分割，提取税率",
              "split_by": "+",
              "extract_index": 1,
              "result_field": "税率",
              "fallback": 0,
              "fallback_description": "若为空则税率为零"
            }
          ],
          "description": "从手工凭证表的摘要列按'&'分出'调整类型'列，为'调整费用'；按'+'，分列出'税率'，若为空，则税率为零"
        }
      ]
    },
    {
      "rule_id": "MANUAL_VOUCHER_SYNC_002",
      "description": "手工凭证表同步到BI损益毛利明细表（手工类）的字段映射规则",
      "version": "1.0",
      "source_tables": "手工凭证表",
      "target_table": "BI损益毛利明细表（手工类）",
      "lookup_tables": [
        {
          "table_name": "关联公司表",
          "description": "用于判断客户/供应商是否为关联公司"
        },
        {
          "table_name": "收入明细表",
          "description": "用于根据科目名称查询收入类型和收入明细"
        }
      ],
      "global_filter": {
        "description": "从手工凭证表中过滤相关数据的总体规则",
        "source_column": "科目名称",
        "operator": "starts_with",
        "values": [
          "主营业务收入",
          "主营业务成本_销售成本",
          "主营业务成本_技术服务成本"
        ]
      },
      "field_mappings": [
        {
          "target_field": "日期",
          "rule_type": "direct_mapping",
          "source_field": "业务时间"
        },
        {
          "target_field": "数据源",
          "rule_type": "constant",
          "value": "手工凭证"
        },
        {
          "target_field": "订单类型",
          "rule_type": "direct_mapping",
          "source_field": "凭证号"
        },
        {
          "target_field": "公司",
          "rule_type": "direct_mapping",
          "source_field": "公司名称"
        },
        {
          "target_field": "店铺名称加平台",
          "rule_type": "direct_mapping",
          "source_field": "平台"
        },
        {
          "target_field": "客户",
          "rule_type": "conditional_extract",
          "source_field": "摘要",
          "conditions": [
            {
              "condition": "摘要内容包含'调整收入'",
              "action": "从'调整收入'关键词后的+号开始提取客户信息",
              "extract_pattern": "调整收入.*?\\+(.+?)(?:\\+|$)",
              "extract_group": 1
            }
          ],
          "description": "从手工凭证表中取：如果摘要列里内容是调整收入，则从'调整收入'关键词后的+号开始可以取到客户信息"
        },
        {
          "target_field": "是否关联客户",
          "rule_type": "lookup",
          "lookup_table": "关联公司表",
          "lookup_field": "客户",
          "match_result": "关联",
          "no_match_result": "非关联",
          "description": "从关联公司表中取，如果是关联公司，则该值为：关联，如果不是这些公司则为非关联"
        },
        {
          "target_field": "商品大类",
          "rule_type": "direct_mapping",
          "source_field": "商品大类"
        },
        {
          "target_field": "供应商",
          "rule_type": "conditional_extract",
          "source_field": "摘要",
          "conditions": [
            {
              "condition": "摘要内容包含'调整成本'或'调整费用'",
              "action": "从'调整成本'或'调整费用'后的+号开始取供应商",
              "extract_pattern": "(?:调整成本|调整费用).*?\\+(.+?)(?:\\+|$)",
              "extract_group": 1
            }
          ],
          "description": "从手工凭证表中取：如果摘要列里内容是调整成本或调整费用，则从调整成本或调整费用的+号后开始取供应商"
        },
        {
          "target_field": "是否关联供应商",
          "rule_type": "lookup",
          "lookup_table": "关联公司表",
          "lookup_field": "供应商",
          "match_result": "关联",
          "no_match_result": "非关联",
          "description": "从关联公司表中取，如果是关联公司，则该值为：关联，如果不是这些公司则为非关联"
        },
        {
          "target_field": "核算类型或返点类型",
          "rule_type": "conditional_value",
          "source_field": "科目名称",
          "conditions": [
            {
              "condition": "科目名称等于'主营业务收入_寄售收入'",
              "value": "净额"
            },
            {
              "condition": "其他",
              "value": "总额"
            }
          ],
          "description": "从手工凭证表中取：从科目名称判断：当前科目名称=主营业务收入_寄售收入，则值为：净额；其他为：总额"
        },
        {
          "target_field": "eas科目",
          "rule_type": "direct_mapping",
          "source_field": "科目编码"
        },
        {
          "target_field": "科目名称",
          "rule_type": "direct_mapping",
          "source_field": "科目名称"
        },
        {
          "target_field": "含税销售额",
          "rule_type": "formula",
          "formula": "eas收入不含税 * (1 + 税率)",
          "description": "含税销售额=eas收入不含税*(1+税率)；该列为计算列",
          "is_computed": true,
          "depends_on": ["eas收入不含税", "税率"]
        },
        {
          "target_field": "含税采购成本",
          "rule_type": "formula",
          "formula": "eas成本不含税 * (1 + 税率)",
          "description": "含税采购成本=eas成本不含税*(1+税率)；该列为计算列",
          "is_computed": true,
          "depends_on": ["eas成本不含税", "税率"]
        },
        {
          "target_field": "含税差额收入",
          "rule_type": "formula",
          "formula": "含税销售额 - 含税采购成本",
          "description": "含税差额收入=含税销售额-含税采购成本；该列为计算列",
          "is_computed": true,
          "depends_on": ["含税销售额", "含税采购成本"]
        },
        {
          "target_field": "eas收入不含税",
          "rule_type": "conditional_formula",
          "source_field": "科目名称",
          "conditions": [
            {
              "condition": "摘要里取'调整类型'为'调整收入'，且科目名称为'主营业务收入_寄售收入'",
              "formula": "贷方发生额",
              "eas成本不含税": 0,
              "description": "eas收入不含税为'贷方发生额'，'eas成本不含税'为零"
            },
            {
              "condition": "科目名称为'主营业务收入_销售收入'或'主营业务收入_技术服务收入'",
              "formula": "贷方发生额",
              "eas成本不含税": 0,
              "description": "eas收入不含税为'贷方发生额'，'eas成本不含税'为零"
            }
          ],
          "description": "从手工凭证表中取，根据摘要里的调整类型和科目名称条件判断取值"
        },
        {
          "target_field": "eas成本不含税",
          "rule_type": "conditional_formula",
          "source_field": "科目名称",
          "conditions": [
            {
              "condition": "摘要里取'调整类型'为'调整成本'，且科目名称为'主营业务收入_寄售收入'",
              "formula": "-贷方发生额",
              "eas收入不含税": 0,
              "description": "eas收入不含税为零，'eas成本不含税'为负数'贷方发生额'"
            },
            {
              "condition": "科目名称为'主营业务成本_销售成本'或'主营业务成本_技术服务成本'",
              "formula": "借方发生额",
              "eas收入不含税": 0,
              "description": "eas收入不含税为零，'eas成本不含税'为'借方发生额'"
            }
          ],
          "description": "从手工凭证表中取，根据摘要里的调整类型和科目名称条件判断取值"
        },
        {
          "target_field": "eas税额",
          "rule_type": "formula",
          "formula": "含税销售额 - eas收入不含税",
          "description": "eas税额=含税销售额-eas收入不含税；该列为计算列",
          "is_computed": true,
          "depends_on": ["含税销售额", "eas收入不含税"]
        },
        {
          "target_field": "eas差额收入不含税",
          "rule_type": "formula",
          "formula": "eas收入不含税 - eas成本不含税",
          "description": "eas差额收入不含税=eas收入不含税-eas成本不含税；该列为计算列",
          "is_computed": true,
          "depends_on": ["eas收入不含税", "eas成本不含税"]
        },
        {
          "target_field": "收入类型",
          "rule_type": "lookup",
          "lookup_table": "收入明细表",
          "lookup_key": "科目名称",
          "source_field": "科目名称",
          "return_field": "收入类型",
          "description": "从手工凭证表中取科目名称，并根据科目名称的值从收入类型与收入明细表中取对应的收入类型"
        },
        {
          "target_field": "收入明细",
          "rule_type": "lookup",
          "lookup_table": "收入明细表",
          "lookup_key": "科目名称",
          "source_field": "科目名称",
          "return_field": "收入明细",
          "description": "从手工凭证表中取科目名称，并根据科目名称的值并从收入类型与收入明细表中取对应的收入明细"
        },
        {
          "target_field": "税率",
          "rule_type": "conditional_value",
          "source_field": "科目名称",
          "conditions": [
            {
              "condition": "科目名称为'主营业务收入_销售收入_销售收入-13%'或'主营业务成本_销售成本_销售成本-13%'",
              "value": 0.13,
              "description": "税率为13%"
            },
            {
              "condition": "科目名称为'主营业务收入_销售收入_销售收入-9%'或'主营业务成本_销售成本_销售成本-9%'",
              "value": 0.09,
              "description": "税率为9%"
            },
            {
              "condition": "科目名称为'主营业务收入_销售收入_销售收入-3%'或'主营业务成本_销售成本_销售成本-3%'",
              "value": 0.03,
              "description": "税率为3%"
            },
            {
              "condition": "科目名称为'主营业务收入_销售收入_销售收入-1%'或'主营业务成本_销售成本_销售成本-1%'",
              "value": 0.01,
              "description": "税率为1%"
            },
            {
              "condition": "其他科目",
              "value": 0.06,
              "description": "税率为6%"
            }
          ],
          "description": "根据科目名称判断税率：含-13%的为13%，含-9%的为9%，含-3%的为3%，含-1%的为1%，其他为6%"
        }
      ]
    }
  ]
}
