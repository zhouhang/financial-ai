FROM node:22-slim AS build

WORKDIR /app

COPY finance-web/package.json finance-web/package-lock.json ./
RUN npm ci

COPY finance-web ./
RUN npm run build

FROM nginx:1.27-alpine AS runtime

ARG OCI_SOURCE=""
ARG OCI_REVISION=""

LABEL org.opencontainers.image.title="finance-web" \
    org.opencontainers.image.description="Tally React web frontend" \
    org.opencontainers.image.source="${OCI_SOURCE}" \
    org.opencontainers.image.revision="${OCI_REVISION}"

COPY docker/nginx.finance-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
