{
  "version": "1.0",
  "tolerance": {
    "date_format": "%Y-%m-%d",
    "amount_diff_max": 0.1
  },
  "description": "西福",
  "data_sources": {
    "finance": {
      "field_roles": {
        "date": "完成时间",
        "amount": "发生-",
        "order_id": [
          "sup订单号"
        ]
      },
      "file_pattern": [
        "ads_finance_d_inc_channel_details_20260105152012277_0_*.xls",
        "ads_finance_d_inc_channel_details_20260105152012277_0_*.csv",
        "ads_finance_d_inc_channel_details_20260105152012277_0_*.xlsx",
        "ads_finance_d_inc_channel_details_20260105152012277_0_*.xlsb",
        "ads_finance_d_inc_channel_details_20260105152012277_0_*.xlsm"
      ]
    },
    "business": {
      "field_roles": {
        "date": "订单时间",
        "amount": "销售额",
        "order_id": [
          "sp订单号"
        ]
      },
      "file_pattern": [
        "1767597466118_*.xlsm",
        "1767597466118_*.xlsx",
        "1767597466118_*.csv",
        "1767597466118_*.xlsb",
        "1767597466118_*.xls"
      ]
    }
  },
  "key_field_role": "order_id",
  "rule_config_text": "1767597466118_*.xlsm：订单号去掉前面的单引号\n1767597466118_*.xlsm：截取订单号前21位\n1767597466118_*.xlsm：相同订单号按金额累加合并\nads_finance_d_inc_channel_details_20260105152012277_0_*.xls：订单号去掉前面的单引号\nads_finance_d_inc_channel_details_20260105152012277_0_*.xls：截取订单号前21位\nads_finance_d_inc_channel_details_20260105152012277_0_*.xls：相同订单号按金额累加合并",
  "custom_validations": [
    {
      "name": "missing_in_business",
      "issue_type": "missing_in_business",
      "display_name": "业务缺失检测",
      "condition_expr": "fin_exists and not biz_exists",
      "detail_template": "{fin_file}存在，{biz_file}无此订单记录"
    },
    {
      "name": "missing_in_finance",
      "issue_type": "missing_in_finance",
      "display_name": "财务缺失检测",
      "condition_expr": "biz_exists and not fin_exists",
      "detail_template": "{biz_file}存在，{fin_file}无此订单记录"
    },
    {
      "name": "amount_mismatch",
      "issue_type": "amount_mismatch",
      "display_name": "金额差异检测",
      "condition_expr": "biz_exists and fin_exists and biz.get('amount') is not None and fin.get('amount') is not None and abs(float(biz.get('amount', 0)) - float(fin.get('amount', 0))) > amount_diff_max",
      "detail_template": "{biz_file}金额 {biz[amount]} vs {fin_file}金额 {fin[amount]}，差额 {amount_diff_formatted} 超出容差 {amount_diff_max}"
    }
  ],
  "field_mapping_text": "业务: date->订单时间, amount->销售额, order_id->sp订单号\n财务: date->完成时间, amount->发生-, order_id->sup订单号",
  "data_cleaning_rules": {
    "global": {
      "global_transforms": [
        {
          "keep": "first",
          "subset": [
            "order_id"
          ],
          "operation": "drop_duplicates",
          "description": "全局去重"
        }
      ]
    },
    "business": {
      "field_transforms": [
        {
          "field": "order_id",
          "operation": "expr",
          "expression": "str(row.get('order_id', '')).lstrip(\"'\") if pd.notna(row.get('order_id', '')) else row.get('order_id', '')",
          "description": "订单号去掉前面的单引号"
        },
        {
          "field": "order_id",
          "operation": "expr",
          "expression": "str(row.get('order_id', ''))[:21] if pd.notna(row.get('order_id', '')) else row.get('order_id', '')",
          "description": "截取订单号前21位"
        }
      ],
      "aggregations": [
        {
          "group_by": "order_id",
          "agg_fields": {
            "date": "first",
            "amount": "sum"
          },
          "description": "相同订单号按金额累加合并"
        }
      ]
    },
    "finance": {
      "field_transforms": [
        {
          "field": "order_id",
          "operation": "expr",
          "expression": "str(row.get('order_id', '')).lstrip(\"'\") if pd.notna(row.get('order_id', '')) else row.get('order_id', '')",
          "description": "订单号去掉前面的单引号"
        },
        {
          "field": "order_id",
          "operation": "expr",
          "expression": "str(row.get('order_id', ''))[:21] if pd.notna(row.get('order_id', '')) else row.get('order_id', '')",
          "description": "截取订单号前21位"
        }
      ],
      "aggregations": [
        {
          "group_by": "order_id",
          "agg_fields": {
            "date": "first",
            "amount": "sum"
          },
          "description": "相同订单号按金额累加合并"
        }
      ]
    }
  }
}